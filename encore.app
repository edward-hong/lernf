{
    "id": "lernf-eau2",
    "lang": "typescript",
    "global_cors": {
        "allow_origins_without_credentials": [
            "https://lernf.com",
            "https://lernf.vercel.app",
            "http://localhost:5173",
            "http://localhost:3000"
        ],
        "allow_origins_with_credentials": [
            "https://lernf.com",
            "https://lernf.vercel.app",
            "http://localhost:5173",
            "http://localhost:3000"
        ],
        "allow_headers": [
            "Content-Type",
            "Authorization",
            "X-Requested-With"
        ]
    }
}
